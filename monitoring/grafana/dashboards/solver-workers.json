{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Solver Queues",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Queue Depth per Solver",
      "description": "Messages waiting in each per-solver Celery queue. Aligns with SolverQueueBacklogWarn (>50, 5m) and SolverQueueBacklogCritical (>200, 2m) alert rules from 06-07.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" },
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "celery_queue_length{queue=~\"solve_.*\"}",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Throughput per Solver (tasks/s)",
      "description": "Rate of tasks published to each per-solver queue (from celery-exporter celery_task_sent_total counter).",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (queue_name) (rate(celery_task_sent_total{queue_name=~\"solve_.*\"}[5m]))",
          "legendFormat": "{{queue_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Solver Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Task Duration P95 per Solver",
      "description": "95th-percentile task runtime per solver queue, computed from celery-exporter celery_task_runtime histogram.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (queue_name, le) (rate(celery_task_runtime_bucket{queue_name=~\"solve_.*\"}[5m])))",
          "legendFormat": "p95 {{queue_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failure Rate per Queue (failures/s)",
      "description": "Rate of failed task executions per queue (celery-exporter celery_task_failed_total). Includes default `celery` queue plus solver queues so on-call can distinguish email/webhook failures from solver failures.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (queue_name) (rate(celery_task_failed_total{queue_name=~\"solve_.*|celery\"}[5m]))",
          "legendFormat": "{{queue_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Worker Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Worker Memory per Container (fraction of limit)",
      "description": "container_memory_working_set_bytes / container_spec_memory_limit_bytes per worker. Same cAdvisor metric used by 06-07 DefaultQueueOOMRisk alert (>0.90 for 2m). jaot_prod_celery_default is sized 256M (aggressive — see D-14 risk).",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{name=~\"jaot_prod_celery_(default|scip|highs)\"} / container_spec_memory_limit_bytes{name=~\"jaot_prod_celery_(default|scip|highs)\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["jaot", "monitoring", "celery", "solvers"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "JAOT Solver Workers",
  "uid": "jaot-solver-workers",
  "version": 1,
  "refresh": "15s"
}
