{
  "name": "simple_test",
  "description": "Simple 3-variable test problem",
  "variables": [
    {"name": "x1", "type": "continuous", "lower_bound": 0, "upper_bound": 5},
    {"name": "x2", "type": "continuous", "lower_bound": 0, "upper_bound": 5},
    {"name": "x3", "type": "continuous", "lower_bound": 0, "upper_bound": 5}
  ],
  "objective": {
    "sense": "minimize",
    "expression": "x1 + 2*x2 + 3*x3"
  },
  "constraints": [
    {"name": "c1", "expression": "2*x1 + x2 + x3 <= 10"},
    {"name": "c2", "expression": "x1 + 3*x2 + x3 <= 8"}
  ]
}
