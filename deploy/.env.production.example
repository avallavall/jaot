# =============================================================================
# JAOT Production Environment Configuration
# =============================================================================
# Business configuration (plans, LLM, Stripe, email, etc.) lives in the
# platform_settings DB table and is managed via the admin panel.
# Only infrastructure vars needed BEFORE the database is reachable go here.
# Variables marked [REQUIRED] must be set before deployment.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL [REQUIRED]
# -----------------------------------------------------------------------------
POSTGRES_USER=jaot
POSTGRES_PASSWORD=                      # [REQUIRED] Strong password
POSTGRES_DB=jaot

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# Redis [REQUIRED]
# -----------------------------------------------------------------------------
REDIS_PASSWORD=                         # [REQUIRED] Strong password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# -----------------------------------------------------------------------------
# Celery [REQUIRED]
# -----------------------------------------------------------------------------
RABBITMQ_USER=jaot
RABBITMQ_PASS=                          # [REQUIRED] Strong password
CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672//
CELERY_RESULT_EXPIRES=604800
CELERY_MAX_RETRIES=3
CELERY_DEFAULT_RETRY_DELAY=300

# -----------------------------------------------------------------------------
# JWT Authentication [REQUIRED]
# -----------------------------------------------------------------------------
JWT_SECRET=                             # [REQUIRED] Min 32 chars: openssl rand -hex 32

# -----------------------------------------------------------------------------
# Qdrant (RAG vector database) [REQUIRED]
# -----------------------------------------------------------------------------
QDRANT_API_KEY=                         # [REQUIRED] Strong API key for Qdrant auth

# -----------------------------------------------------------------------------
# Environment & Server [REQUIRED]
# -----------------------------------------------------------------------------
DEBUG=False
HOST=0.0.0.0
PORT=8001
WORKERS=4
RELOAD=False
FRONTEND_URL=https://jaot.io
ALLOWED_ORIGINS=["https://jaot.io"]

# -----------------------------------------------------------------------------
# Monitoring [REQUIRED]
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=jaot_admin
GRAFANA_ADMIN_PASSWORD=                 # [REQUIRED] Grafana admin password
ALERT_EMAIL_RECIPIENT=                  # [REQUIRED] ops@jaot.io
RESEND_API_KEY=                         # [DOCS ONLY] Alertmanager reads from secrets/ mount

# -----------------------------------------------------------------------------
# Plausible self-hosted analytics (Phase 8) [REQUIRED if plausible services up]
# -----------------------------------------------------------------------------
# SECRET_KEY_BASE must be at least 64 chars. Generate with: openssl rand -base64 48
PLAUSIBLE_SECRET_KEY_BASE=              # [REQUIRED] >=64 chars: openssl rand -base64 48
# Strong random password for Plausible's dedicated Postgres 16 instance
# (NOT JAOT's postgres:18 — Plausible pins 16-alpine).
PLAUSIBLE_POSTGRES_PASSWORD=            # [REQUIRED] Strong password (e.g. openssl rand -base64 24)

# =============================================================================
# All other configuration (Stripe, SMTP, LLM, plans, storage, Discourse,
# rate limits, etc.) is managed in the platform_settings DB
# table via the admin panel. See the settings_registry.py for all available
# keys and their default values.
# =============================================================================
