# =============================================================================
# JAOT — Minimal .env (infrastructure only)
# =============================================================================
# Business configuration (plans, LLM, Stripe, email, etc.) lives in the
# platform_settings DB table and is managed via the admin panel.
# Only infrastructure vars that must be set BEFORE the database is
# reachable belong here.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://jaot:jaot@localhost:5432/jaot
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# PostgreSQL credentials (used by docker-compose, not by app directly)
POSTGRES_USER=jaot
POSTGRES_PASSWORD=jaot
POSTGRES_DB=jaot

# -----------------------------------------------------------------------------
# Redis (rate limiting + Celery result backend)
# Leave empty to use in-memory fallback (development without Redis).
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Celery (async task processing)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=amqp://jaot:jaot@localhost:5672//
CELERY_RESULT_EXPIRES=604800
CELERY_MAX_RETRIES=3
CELERY_DEFAULT_RETRY_DELAY=300

# RabbitMQ credentials (used by docker-compose)
RABBITMQ_USER=jaot
RABBITMQ_PASS=jaot

# -----------------------------------------------------------------------------
# JWT secret — REQUIRED when DEBUG=False (production)
# In development (DEBUG=True), leave empty for auto-generated secret.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=

# -----------------------------------------------------------------------------
# Environment & server bootstrap
# -----------------------------------------------------------------------------
DEBUG=True
HOST=0.0.0.0
PORT=8001
WORKERS=1
RELOAD=True

# -----------------------------------------------------------------------------
# First-run admin bootstrap
# On the FIRST start against an empty database, the API creates this admin
# user + organization automatically — then just log in at the frontend.
# No-op once any user exists. Password: minimum 12 characters.
# Leave empty to skip (create the admin later with:
#   docker compose exec api python -m app.shared.db.seed_admin)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-please
SEED_ADMIN_NAME=Admin
# SEED_ADMIN_ORG_NAME=My Organization
# SEED_ORG_CREDITS=10000

# -----------------------------------------------------------------------------
# Frontend / CORS
# In production, set to your actual domain: ["https://app.jaot.io"]
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# RAG / Qdrant (vector search for LLM formulation assistant)
# Leave empty to disable RAG (formulation works without it).
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Monitoring (docker-compose only)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=
