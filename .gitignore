# Production secrets (API keys, mounted into containers)
# Anchored to repo root only (/secrets/) so deploy/secrets/ can be
# managed separately (see Phase 7.4 / D-01 block below).
/secrets/

# Phase 7.4 / D-01 — never commit the real Hexaly platform license.
# deploy/secrets/*.lic is gitignored; the .example template is tracked.
# /secrets/ above is root-anchored to avoid catching deploy/secrets/.
deploy/secrets/*.lic
!deploy/secrets/*.lic.example

# Phase 8 / D-08 — never commit Plausible admin credentials.
# The first-admin bootstrap of Plausible CE v3 has no init-admin CLI;
# the admin email + password are persisted to deploy/secrets/plausible_admin.txt
# on the VPS only (chmod 600, chown jaot:jaot). This .gitignore rule is
# defense-in-depth against accidental `git add deploy/secrets/` by a future
# operator. See 08-RESEARCH.md and 08-CONTEXT.md D-08 for details.
deploy/secrets/plausible_admin.txt

# Next.js build output (root-level, e.g. from IDE)
.next/
openapi.json

# Stray node_modules at repo root (e.g. accidental Vite installs from IDE plugins)
node_modules/

# Claude Code agent workspaces — ephemeral, never commit
.claude/worktrees/
.claude/scheduled_tasks.lock

# Phase 12.5 — local mutmut harness scratch (underscore-prefixed dev helpers).
# The reproducible path is .woodpecker/mutmut.yml + pyproject.toml [tool.mutmut];
# these per-module scope/run/show scripts are kept locally but not committed.
# (check_triage_complete.py — no underscore — IS committed as the completeness gate.)
.planning/phases/12.5-mutation-testing-on-5-critical-modules/_*.py

# Production database backups live inside the checkout on the VPS (/opt/jaot/backups).
# Dumps must NEVER enter git — this repo is heading to a public release.
backups/

