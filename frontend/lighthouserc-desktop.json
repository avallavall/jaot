{
  "ci": {
    "collect": {
      "url": [
        "https://jaot.io",
        "https://jaot.io/pricing",
        "https://jaot.io/marketplace",
        "https://jaot.io/marketplace/official_assignment",
        "https://jaot.io/docs/getting-started/introduction",
        "https://jaot.io/contact"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage --disable-gpu"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/desktop"
    }
  }
}
