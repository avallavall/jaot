{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/pricing",
        "http://127.0.0.1:3000/docs/getting-started/introduction",
        "http://127.0.0.1:3000/contact"
      ],
      "numberOfRuns": 3,
      "settings": {
        "formFactor": "mobile",
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage --disable-gpu",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4
        }
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/gate"
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "^https?://[^/]+/$",
          "aggregationMethod": "median",
          "assertions": {
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 4300
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 400
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "categories:seo": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.95
              }
            ]
          }
        },
        {
          "matchingUrlPattern": ".*/pricing$",
          "aggregationMethod": "median",
          "assertions": {
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 4450
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 500
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "categories:seo": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.95
              }
            ]
          }
        },
        {
          "matchingUrlPattern": ".*/introduction$",
          "aggregationMethod": "median",
          "assertions": {
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 4700
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 250
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "categories:seo": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.95
              }
            ]
          }
        },
        {
          "matchingUrlPattern": ".*/contact$",
          "aggregationMethod": "median",
          "assertions": {
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 5900
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 250
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "categories:seo": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.95
              }
            ]
          }
        }
      ]
    }
  }
}
