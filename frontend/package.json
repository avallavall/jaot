{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "npx tsx src/scripts/build-search-index.ts && (curl -sf http://localhost:8001/openapi.json -o ../openapi.json && npm run generate-types || echo 'API not running, skipping type generation')",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "check-i18n": "node scripts/check-i18n-keys.mjs",
    "test": "NODE_OPTIONS=--max-old-space-size=4096 vitest run",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=4096 vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate-types": "openapi-typescript ../openapi.json -o src/lib/generated/api.ts --root-types --root-types-no-schema-prefix --alphabetize",
    "generate-search": "npx tsx src/scripts/build-search-index.ts",
    "regenerate": "curl -sf http://localhost:8001/openapi.json -o ../openapi.json && npm run generate-types && npm run generate-search && echo '✓ api.ts + search-index.json regenerated'",
    "check-types": "openapi-typescript ../openapi.json -o src/lib/generated/api.ts --root-types --root-types-no-schema-prefix --alphabetize && git diff --exit-code src/lib/generated/api.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.9",
    "@tailwindcss/typography": "^0.5.20",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/markdown": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "flexsearch": "^0.7.31",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.555.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "radix-ui": ">=1.5.0 <1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-katex": "^3.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "shiki": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "web-vitals": "^5.3.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/flexsearch": "^0.7.6",
    "@types/katex": "^0.16.8",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-katex": "^3.0.4",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "intl-messageformat": "^11.2.9",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  }
}
